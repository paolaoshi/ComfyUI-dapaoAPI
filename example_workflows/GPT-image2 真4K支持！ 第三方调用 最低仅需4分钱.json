      "widgets_values": [
        "```json\n{\n  \"prompt_metadata\": {\n    \"original_input\": \"一群大学女生在宿舍自拍\",\n    \"generation_style\": \"contemporary smartphone photography\",\n    \"primary_focus\": \"candid group selfie with environmental storytelling\"\n  },\n  \"subject\": {\n    \"type\": \"group of young women\",\n    \"description\": \"4-6 Chinese university students, age 18-22, diverse appearances within East Asian beauty standards, natural youthful skin with occasional blemishes, genuine expressions ranging from playful to slightly awkward, comfortable casual poses suggesting close friendship\",\n    \"pose_and_action\": \"clustered together in classic selfie formation, some leaning forward, others tucked behind, arms extended or using selfie stick, heads tilted at various angles, spontaneous mid-laughter or exaggerated pout poses, slight motion blur from movement\",\n    \"expression_and_emotion\": \"uninhibited joy, inside jokes visible in shared glances, occasional closed eyes from laughter, authentic unposed moments mixed with practiced selfie awareness\",\n    \"clothing_and_styling\": {\n      \"outfit\": \"casual dormitory attire - oversized hoodies, pajama sets, graphic t-shirts, comfortable sweatpants, mix of current fast fashion trends and personal favorites\",\n      \"accessories\": [\"hair clips and scrunchies\", \"minimal jewelry\", \"eyeglasses on some\", \"wireless earbuds around neck\", \"smartphone cases with charms\"],\n      \"hair\": \"varied styles - ponytails, loose natural hair, morning bedhead, some with face-framing strands, dyed highlights on one or two\",\n      \"makeup\": \"minimal to light daily makeup, some bare-faced, lip tint, natural brows, occasional acne patches visible\"\n    }\n  },\n  \"environment\": {\n    \"location\": \"Chinese university dormitory room\",\n    \"setting_description\": \"compact shared living space, bunk beds with personalized bedding, string lights and photos decorating walls, cluttered desks with textbooks and laptops, laundry drying rack, small refrigerator, mirror with sticky notes, window with university view\",\n    \"time_of_day\": \"evening or late afternoon, artificial lighting mixed with fading daylight\",\n    \"weather_and_atmosphere\": \"indoor cozy atmosphere, slightly humid warm air, sense of temporary privacy and freedom\",\n    \"props_and_objects\": [\"smartphone held by front person\", \"scattered cosmetics on desk\", \"instant camera photos taped to wall\", \"plush toys on bed\", \"folded clothes\", \"takeout containers\", \"academic planners\", \"shared snacks\"],\n    \"spatial_layout\": \"tight intimate framing, ceiling visible, walls closing in creating cozy compression, multiple planes of depth with background details\"\n  },\n  \"photography\": {\n    \"camera_angle\": \"arm's length selfie perspective, slight upward angle typical of front camera, wide-angle distortion at edges\",\n    \"shot_type\": \"medium close-up group shot, faces dominating frame with environment peeking around\",\n    \"lens_and_focal_length\": \"smartphone ultra-wide front camera equivalent, 24mm with characteristic edge distortion\",\n    \"depth_of_field\": \"deep focus from small sensor, everything relatively sharp, slight softness from motion or low light\",\n    \"lighting\": {\n      \"type\": \"mixed ambient and phone screen glow\",\n      \"direction\": \"frontal fill from phone screen, overhead dormitory fluorescent, warm desk lamp\",\n      \"quality\": \"uneven lighting with shadows under chins, highlights on closest faces, typical indoor selfie conditions\",\n      \"color_temperature\": \"mixed warm and cool sources creating color variation across faces\"\n    },\n    \"composition\": \"centered group with slight asymmetry, faces arranged in triangular cluster, background elements providing context without distraction\",\n    \"camera_settings\": \"auto smartphone exposure, possible slight overexposure from face detection, HDR processing visible\"\n  },\n  \"color_and_mood\": {\n    \"color_palette\": [\"warm skin tones\", \"LED string light amber\", \"cool fluorescent white\", \"pastel bedding\", \"phone screen blue glow\"],\n    \"color_grading\": \"natural smartphone processing, slight saturation boost, skin tone smoothing algorithms, authentic contemporary look\",\n    \"mood_and_atmosphere\": \"youthful intimacy, fleeting freedom between responsibilities, friendship documentation, unguarded authenticity, generational ritual\",\n    \"visual_tone\": \"warm and immediate, slightly noisy from low light, genuinely contemporary without aesthetic pretension\"\n  },\n  \"style_and_quality\": {\n    \"artistic_style\": \"unfiltered social media documentation, Gen Z visual culture, anti-aesthetic authenticity\",\n    \"reference_artists\": [\"contemporary youth photography\", \"Instagram and Xiaohongshu visual language\"],\n    \"rendering_quality\": \"smartphone camera quality, slight compression artifacts, authentic noise pattern, unpolished realism\",\n    \"post_processing\": \"minimal or default phone filters, possible beauty mode subtlety, timestamp or interface elements optional\",\n    \"resolution_and_detail\": \"adequate for screen viewing, slight softness acceptable, authentic to capture method\"\n  },\n  \"technical_parameters\": {\n    \"aspect_ratio\": \"9:16 vertical or 4:5 square crop typical of social platforms\",\n    \"image_quality\": \"authentic smartphone capture, realistic lighting challenges, genuine moment preservation\",\n    \"negative_prompt_suggestions\": [\"professional studio lighting\", \"perfect symmetry\", \"model poses\", \"empty pristine room\", \"professional camera quality\", \"vintage aesthetic\", \"overly processed beauty filters\"]\n  }\n}\n```"
